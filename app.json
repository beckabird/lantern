{
  "expo": {
    "name": "Lantern",
    "slug": "lantern",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lantern",
    "userInterfaceStyle": "automatic",
    "ios": { "supportsTablet": true },
